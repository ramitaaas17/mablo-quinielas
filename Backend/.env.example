# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_HOST=localhost
DB_NAME=quiniepicks_db

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
# Genera una clave segura: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_LARGA

# ─── CORS (dominios permitidos separados por coma) ───────────────────────────
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ─── CORREO (recuperación de contraseña) ─────────────────────────────────────
# Usa un correo Gmail con "Contraseña de aplicación" (ver README)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=soporte.tuapp@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=Quiniepicks

# ─── OPCIONAL: Redis para rate limiting distribuido ───────────────────────────
# REDIS_URL=redis://localhost:6379/0
